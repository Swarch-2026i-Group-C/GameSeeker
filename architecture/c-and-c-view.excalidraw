    {
      "type": "text",
      "id": "usersvc_detail",
      "x": 1155, "y": 176,
      "width": 300, "height": 180,
      "text": "TypeScript / Hono / Prisma\nPort: 3001 ext → 3000 int\n\nAuth: better-auth library\nTables: User · Session · Account\n\nEndpoints:\nPOST /auth/sign-up/email\nPOST /auth/sign-in/email\nGET  /auth/session\nPOST /auth/sign-out\n\nGET  /wishlist?userId=\nPOST /wishlist { userId, gameId, gameName }\nDELETE /wishlist/:id",
      "originalText": "TypeScript / Hono / Prisma\nPort: 3001 ext → 3000 int\n\nAuth: better-auth library\nTables: User · Session · Account\n\nEndpoints:\nPOST /auth/sign-up/email\nPOST /auth/sign-in/email\nGET  /auth/session\nPOST /auth/sign-out\n\nGET  /wishlist?userId=\nPOST /wishlist { userId, gameId, gameName }\nDELETE /wishlist/:id",
      "fontSize": 11,
