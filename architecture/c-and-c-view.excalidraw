    {
      "type": "text",
      "id": "legend_title",
      "x": 1500, "y": 133,
      "width": 340, "height": 22,
      "text": "ARCHITECTURAL STYLES",
      "originalText": "ARCHITECTURAL STYLES",
      "fontSize": 15,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "top",
      "strokeColor": "#1e40af",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
