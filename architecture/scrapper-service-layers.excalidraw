    { "type": "text", "id": "config_body", "x": 1063, "y": 400, "width": 209, "height": 120,
      "text": "RABBITMQ_HOST\nRABBITMQ_PORT  :5672\nRABBITMQ_USER\nRABBITMQ_PASSWORD\nQUEUE_NAME\n  game_prices_queue\n\nLoaded from .env\nvia python-dotenv",
      "originalText": "RABBITMQ_HOST\nRABBITMQ_PORT  :5672\nRABBITMQ_USER\nRABBITMQ_PASSWORD\nQUEUE_NAME\n  game_prices_queue\n\nLoaded from .env\nvia python-dotenv",
