    { "type": "text", "id": "schema_title", "x": 1305, "y": 355, "width": 240, "height": 16,
      "text": "GAME RESULT SCHEMA",
      "originalText": "GAME RESULT SCHEMA",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#60a5fa", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 702, "version": 1, "versionNonce": 703, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "schema_body", "x": 1305, "y": 376, "width": 240, "height": 200,
      "text": "{\n  \"store\": \"Steam\",\n  \"name\": \"Elden Ring\",\n  \"price_cents\": 9999,\n  \"original_price_cents\": 19999,\n  \"currency\": \"COP\",\n  \"url\": \"store.steam...\"\n}\n\nCOMPARE RESULT:\n{\n  \"game\": \"Elden Ring\",\n  \"prices\": [ ...results ],\n  \"cheapest\": { ...above }\n}",
      "originalText": "{\n  \"store\": \"Steam\",\n  \"name\": \"Elden Ring\",\n  \"price_cents\": 9999,\n  \"original_price_cents\": 19999,\n  \"currency\": \"COP\",\n  \"url\": \"store.steam...\"\n}\n\nCOMPARE RESULT:\n{\n  \"game\": \"Elden Ring\",\n  \"prices\": [ ...results ],\n  \"cheapest\": { ...above }\n}",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 704, "version": 1, "versionNonce": 705, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },
    { "type": "text", "id": "schema_fuzzy_title", "x": 1305, "y": 590, "width": 240, "height": 16,
      "text": "FUZZY MATCH LOGIC",
      "originalText": "FUZZY MATCH LOGIC",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#60a5fa", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 706, "version": 1, "versionNonce": 707, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "schema_fuzzy_body", "x": 1305, "y": 610, "width": 240, "height": 220,
      "text": "1. normalize(text)\n   unicodedata.normalize\n   NFD → remove accents\n   lowercase\n   remove special chars\n   collapse whitespace\n\n2. SequenceMatcher(\n     normalize(query),\n     normalize(title)\n   ).ratio()\n\n3. threshold ≥ 0.4\n   (all scrapers)\n\n4. GOG substring boost:\n   if query in title:\n     ratio = max(ratio, 0.8)",
      "originalText": "1. normalize(text)\n   unicodedata.normalize\n   NFD → remove accents\n   lowercase\n   remove special chars\n   collapse whitespace\n\n2. SequenceMatcher(\n     normalize(query),\n     normalize(title)\n   ).ratio()\n\n3. threshold ≥ 0.4\n   (all scrapers)\n\n4. GOG substring boost:\n   if query in title:\n     ratio = max(ratio, 0.8)",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#22c55e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 708, "version": 1, "versionNonce": 709, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 }

