    { "type": "rectangle", "id": "steam_box", "x": 60, "y": 604, "width": 195, "height": 215,
      "strokeColor": "#1e3a5f", "backgroundColor": "#93c5fd", "fillStyle": "solid",
      "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 510, "version": 1, "versionNonce": 511, "isDeleted": false, "groupIds": [],
