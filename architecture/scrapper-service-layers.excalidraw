    { "type": "text", "id": "gamesvc_body", "x": 70, "y": 400, "width": 520, "height": 120,
      "text": "search_all_stores(game_name)\n  → calls each scraper.search(), aggregates non-null results\n\nsearch_specific_store(store_name, game_name)\n  → map lookup → scraper.search()\n\nget_trending_games(store_name)\n  → scraper.scrape()  then  broker.publish()\n\nbulk_compare(game_names)  →  delegates to PriceComparator",
      "originalText": "search_all_stores(game_name)\n  → calls each scraper.search(), aggregates non-null results\n\nsearch_specific_store(store_name, game_name)\n  → map lookup → scraper.search()\n\nget_trending_games(store_name)\n  → scraper.scrape()  then  broker.publish()\n\nbulk_compare(game_names)  →  delegates to PriceComparator",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 414, "version": 1, "versionNonce": 415, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },

    { "type": "rectangle", "id": "comparator_box", "x": 625, "y": 368, "width": 400, "height": 165,
      "strokeColor": "#1e3a5f", "backgroundColor": "#60a5fa", "fillStyle": "solid",
      "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 420, "version": 1, "versionNonce": 421, "isDeleted": false, "groupIds": [],
      "boundElements": [], "link": null, "locked": false, "roundness": {"type": 3} },

    { "type": "text", "id": "comparator_title", "x": 635, "y": 378, "width": 380, "height": 18,
      "text": "PriceComparator  (price_comparator.py)",
      "originalText": "PriceComparator  (price_comparator.py)",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 422, "version": 1, "versionNonce": 423, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "text", "id": "comparator_body", "x": 635, "y": 400, "width": 380, "height": 120,
      "text": "compare(game_names: list)\n  → for each game: call all scrapers\n  → collect results where price_cents > 0\n  → cheapest = min(results, key=price_cents)\n  → sleep(0.5s) between games  [rate limit]\n\nprint_comparison(results)\n  → pretty-print table with discount %",
      "originalText": "compare(game_names: list)\n  → for each game: call all scrapers\n  → collect results where price_cents > 0\n  → cheapest = min(results, key=price_cents)\n  → sleep(0.5s) between games  [rate limit]\n\nprint_comparison(results)\n  → pretty-print table with discount %",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#ffffff", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 424, "version": 1, "versionNonce": 425, "isDeleted": false, "groupIds": [],
      "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5 },

