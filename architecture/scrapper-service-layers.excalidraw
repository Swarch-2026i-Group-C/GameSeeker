    { "type": "text", "id": "rabbitmq_broker_body", "x": 928, "y": 633, "width": 334, "height": 70,
      "text": "connect()  → pika.BlockingConnection, declare durable queue\npublish(games)  → iterate, json.dumps each game\n  → basic_publish(delivery_mode=2 persistent)\nclose()  → connection.close()",
      "originalText": "connect()  → pika.BlockingConnection, declare durable queue\npublish(games)  → iterate, json.dumps each game\n  → basic_publish(delivery_mode=2 persistent)\nclose()  → connection.close()",
