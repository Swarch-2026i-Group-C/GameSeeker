		{
			"type": "text",
			"id": "kvx2vK8V",
			"x": 72,
			"y": 792,
			"width": 246.09375,
			"height": 150,
			"text": "WISHLISTREPOSITORY\n(wishlist.repository.ts)\n\nfindByUserId(userId)\n  → Wishlist with games ordered by addedAt\n\naddGame(userId, gameId, gameName)\n  → upsert Wishlist (create if missing)\n  → create Game entry\n\ndeleteGameById(id)\n  → delete Game by UUID",
			"originalText": "WISHLISTREPOSITORY\n(wishlist.repository.ts)\n\nfindByUserId(userId)\n  → Wishlist with games ordered by addedAt\n\naddGame(userId, gameId, gameName)\n  → upsert Wishlist (create if missing)\n  → create Game entry\n\ndeleteGameById(id)\n  → delete Game by UUID",
			"fontSize": 10,
			"fontFamily": 3,
			"textAlign": "left",
			"verticalAlign": "top",
			"strokeColor": "#ffffff",
