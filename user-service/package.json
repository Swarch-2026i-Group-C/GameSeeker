{
  "name": "user-service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "vitest": {
    "environment": "node"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.5",
    "@hono/node-server": "^1.19.11",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.3",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "hono": "^4.12.8",
    "lz-string": "^1.5.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
